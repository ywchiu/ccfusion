{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ccfusion.dev/schemas/approved-plan.schema.json",
  "title": "Approved Plan",
  "description": "Written only on APPROVE_PLAN. Its existence unlocks implementation by the single writer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task",
    "scope",
    "implementation_steps",
    "test_plan",
    "rollback_plan",
    "execution_permission"
  ],
  "properties": {
    "task": { "type": "string", "minLength": 1 },
    "scope": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "non_scope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "files_to_inspect": {
      "type": "array",
      "items": { "type": "string" }
    },
    "files_likely_to_modify": {
      "type": "array",
      "items": { "type": "string" }
    },
    "implementation_steps": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "test_plan": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "rollback_plan": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "risks_accepted": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risks_rejected": {
      "type": "array",
      "items": { "type": "string" }
    },
    "external_research_used": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reviewer_feedback_incorporated": {
      "type": "array",
      "items": { "type": "string" }
    },
    "execution_permission": {
      "type": "string",
      "const": "Claude Code main session is the only executor."
    }
  }
}
