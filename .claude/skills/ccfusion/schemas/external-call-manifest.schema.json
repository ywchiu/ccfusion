{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ccfusion.dev/schemas/external-call-manifest.schema.json",
  "title": "External Call Manifest",
  "description": "Safety review per (target + data-scope), not per call. Reused across calls with the same target and data scope.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "target",
    "data_scope_name",
    "purpose",
    "data_allowed_to_leave",
    "data_excluded",
    "user_or_customer_data_present",
    "secrets_present",
    "approved_for_calls"
  ],
  "properties": {
    "target": {
      "type": "string",
      "enum": ["Gemini", "Codex", "Other"]
    },
    "data_scope_name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Short human-readable slug. No hashes. e.g. public-docs-no-code."
    },
    "purpose": { "type": "string", "minLength": 1 },
    "data_allowed_to_leave": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "data_excluded": {
      "type": "array",
      "items": { "type": "string" }
    },
    "redaction_method": { "type": "string" },
    "sensitive_data_check": { "type": "string" },
    "user_or_customer_data_present": { "type": "boolean" },
    "secrets_present": { "type": "boolean" },
    "approved_for_calls": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^call-[0-9]{3,}$"
      },
      "description": "Call ids covered by this manifest, e.g. call-001."
    },
    "reviewer_notes": { "type": "string" }
  }
}
